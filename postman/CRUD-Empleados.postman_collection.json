{
  "info": {
    "_postman_id": "3b64f0b8-18df-4d47-b899-7a4e3f450001",
    "name": "CRUD Empleados - EMP Key",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección para probar CRUD de empleados con clave canónica EMP-<n>."
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{password}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "claveEmpleado",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Listar empleados",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/empleados",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Crear empleado",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana Postman\",\n  \"direccion\": \"Calle 10\",\n  \"telefono\": \"5551000\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/empleados",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Respuesta contiene clave', function () {",
              "  pm.expect(json.clave).to.be.a('string');",
              "  pm.expect(json.clave).to.match(/^EMP-[0-9]+$/);",
              "});",
              "pm.collectionVariables.set('claveEmpleado', json.clave);",
              "pm.environment.set('claveEmpleado', json.clave);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Consultar por clave",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/empleados/{{claveEmpleado}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados",
            "{{claveEmpleado}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('La clave coincide', function () {",
              "  pm.expect(json.clave).to.eql(pm.collectionVariables.get('claveEmpleado'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Actualizar empleado",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana Postman Editada\",\n  \"direccion\": \"Calle 20\",\n  \"telefono\": \"5552000\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/empleados/{{claveEmpleado}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados",
            "{{claveEmpleado}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('Nombre actualizado', function () {",
              "  pm.expect(json.nombre).to.eql('Ana Postman Editada');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Eliminar empleado",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/empleados/{{claveEmpleado}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados",
            "{{claveEmpleado}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 204', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Confirmar 404 tras eliminar",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/empleados/{{claveEmpleado}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "empleados",
            "{{claveEmpleado}}"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
